{
  "name": "Hello YaHei",
  "version": "1.1.0",
  "description": "It will change Chinese fonts to Microsoft YaHei and others to Segoe UI, without breaking icon fonts. by LongQiang",
  "manifest_version": 3,
  "icons": { "128": "icon128.png", "512": "icon512.png" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "css": ["font.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["font-fix.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
